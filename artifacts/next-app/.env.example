# ============================================================
# Graphe Notes — Next.js environment variables
# ============================================================
# For Vercel: add these in Project Settings → Environment Variables.
# For local dev: copy this file to .env.local inside artifacts/next-app/
#   OR keep using the repo-root .env (loaded automatically by next.config.ts).
# ============================================================

# --- Supabase (required for auth + data) ---
# Exposed to the browser — safe to be public.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — NEVER expose to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (required for schema migrations via `pnpm db push`) ---
# Not needed by the Next.js runtime; only used by the @workspace/db CLI.
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
