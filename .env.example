# Copy this file to .env and fill in your values.
# The app runs in demo mode without these — see README.md.

# --- Supabase (required for real auth + data) ---
# Get these from your Supabase project dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (required for schema migrations) ---
# Supabase project dashboard → Project Settings → Database → Connection string (Session mode)
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# --- Dev server (optional, defaults shown) ---
PORT=5173
API_PORT=3001
BASE_PATH=/
