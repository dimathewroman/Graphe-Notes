# Copy this file to .env and fill in your values.
# The app runs in demo mode without these — see README.md.

# --- Supabase (required for auth + data) ---
# Get these from your Supabase project dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (required for schema migrations via `pnpm db push`) ---
# Supabase project dashboard → Project Settings → Database → Connection string (Session mode)
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# --- Analytics ---
NEXT_PUBLIC_POSTHOG_KEY=phc_your-project-token-here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- AI ---
AI_KEY_ENCRYPTION_SECRET=your-32-byte-hex-secret-here
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override the saved local LLM endpoint when running the dev server.
# Useful if you store a public tunnel URL (e.g. cloudflared) in your account
# for the Vercel deployment but want local dev to hit your machine directly.
# NEXT_PUBLIC_* vars are inlined at build time, so leave this unset on Vercel.
# NEXT_PUBLIC_LOCAL_LLM_DEV_OVERRIDE=http://localhost:8000

# --- Security / Cron ---
# Generate a random secret: openssl rand -hex 32
# Add this to Vercel environment variables (Production + Preview) so Vercel can call the cron.
CRON_SECRET=your-cron-secret-here
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here
# DSN is public — safe to expose client-side. Find it in Sentry → Project Settings → Client Keys.
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0
